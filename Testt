    ["Fisher's Island"]   = { area = "Fisher's Island",   fallback = Vector3.new(-23663, 6, 7) },
    ["Blizzard Hills"]    = { area = "Blizzard Hills",    fallback = Vector3.new(-21425, 4, -100922) },
