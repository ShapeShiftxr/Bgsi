[span_4](start_span)}

local savedCFrames = {} 
local fishing = false
local currentAreaName = ""

-- Sucht die aktuelle Insel aus der Quest-Beschreibung
local function getActiveQuestIsland()
    local d = LocalData:Get()[span_4](end_span)
    if d and d.Quests then
        for _, q in pairs(d.Quests) do
            -- Prüft, ob es eine Sailor-Quest ist und welche Insel im Text steht
            for name, _ in pairs(FISH_WORLDS) do
                if q.Description and q.Description:find(name) then
                    return name
                end
            end
        end
    end
    return nil
end

